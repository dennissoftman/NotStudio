# Copy to .env and adjust. All settings are prefixed NOT_STUDIO_.
NOT_STUDIO_DEBUG=false

# CORS origins allowed to call the API.
# NOT_STUDIO_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Audio defaults.
NOT_STUDIO_SAMPLE_RATE=44100
NOT_STUDIO_CHANNELS=2
NOT_STUDIO_DEFAULT_MUSIC_PROVIDER=stable_audio_local
NOT_STUDIO_DEFAULT_MUSIC_MODEL=medium
# Wait for the local medium model to be hot before the API reports healthy.
NOT_STUDIO_PRELOAD_LOCAL_MODEL_ON_STARTUP=true

# RunPod Stable Audio batch endpoint.
# The worker contract is documented in the project README.
# NOT_STUDIO_RUNPOD_ENDPOINT_ID=
# NOT_STUDIO_RUNPOD_API_KEY=
# NOT_STUDIO_RUNPOD_BASE_URL=https://api.runpod.ai/v2
# NOT_STUDIO_RUNPOD_TIMEOUT_SECONDS=3600
# Network-volume S3 access used by the API to stream generated FLAC files.
# NOT_STUDIO_RUNPOD_VOLUME_ID=
# NOT_STUDIO_RUNPOD_S3_ENDPOINT_URL=https://s3api-EU-RO-1.runpod.io
# NOT_STUDIO_RUNPOD_S3_ACCESS_KEY_ID=
# NOT_STUDIO_RUNPOD_S3_SECRET_ACCESS_KEY=
# NOT_STUDIO_RUNPOD_S3_REGION=EU-RO-1
