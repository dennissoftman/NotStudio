# Copy to .env and adjust. All settings are prefixed NOT_STUDIO_.
NOT_STUDIO_DEBUG=false

# CORS origins allowed to call the API.
# NOT_STUDIO_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Audio defaults.
NOT_STUDIO_SAMPLE_RATE=44100
NOT_STUDIO_CHANNELS=2
# Embedded in generated and exported FLAC metadata.
NOT_STUDIO_TRACK_AUTHOR="Not Studio"
# Keep startup cold so the planner is the first model loaded by the scheduler.
NOT_STUDIO_PRELOAD_LOCAL_MODEL_ON_STARTUP=false

# Natural-language album planner (Apache 2.0).
NOT_STUDIO_PLANNER_PROVIDER=qwen_local
NOT_STUDIO_PLANNER_MODEL="Qwen/Qwen3-4B-Instruct-2507"
NOT_STUDIO_PLANNER_MAX_MODEL_LEN=8192
NOT_STUDIO_PLANNER_GPU_MEMORY_UTILIZATION=0.80

# Cover generation (FLUX.2 Klein 4B is Apache 2.0).
NOT_STUDIO_IMAGE_PROVIDER=flux2_klein_local
NOT_STUDIO_IMAGE_MODEL="black-forest-labs/FLUX.2-klein-4B"
NOT_STUDIO_COVER_GENERATION_SIZE=1024
NOT_STUDIO_COVER_OUTPUT_SIZE=2048
NOT_STUDIO_COVER_MAX_OUTPUT_SIZE=4096
NOT_STUDIO_COVER_STEPS=4

# Release the resident model after this many idle seconds.
NOT_STUDIO_GPU_MODEL_IDLE_SECONDS=180
