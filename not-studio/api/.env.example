# Copy to .env and adjust. All settings are prefixed NOT_STUDIO_.
NOT_STUDIO_DEBUG=false

# CORS origins allowed to call the API.
# NOT_STUDIO_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# Audio defaults.
NOT_STUDIO_SAMPLE_RATE=44100
NOT_STUDIO_CHANNELS=2
# Embedded in generated and exported FLAC metadata.
NOT_STUDIO_TRACK_AUTHOR="Not Studio"
# Warm ACE-Step asynchronously in the persistent generation worker.
NOT_STUDIO_PRELOAD_LOCAL_MODEL_ON_STARTUP=true
