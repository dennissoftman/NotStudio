# Copy to .env and adjust. All settings are prefixed RADIO_.
RADIO_DEBUG=false

# Redis (arq queue). Matches docker-compose.
RADIO_REDIS_URL=redis://localhost:6379

# CORS origins allowed to call the API (the Vite dev server + preview server).
# RADIO_CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Audio defaults
RADIO_SAMPLE_RATE=44100
RADIO_CHANNELS=2

# Pre-allocated buffer policy (feature #4)
RADIO_BUFFER_MIN_SECONDS=900       # keep >= 15 min ready ahead of playout
RADIO_BATCH_TARGET_SECONDS=1080    # generate ~18 min per batch
RADIO_BATCH_MAX_SECONDS=1200       # never exceed 20 min per batch

# Streaming
RADIO_FFMPEG_PATH=ffmpeg
RADIO_STREAM_MP3_BITRATE=128k

# Reuse of the parent Neural Radio engine for real backends (subprocess).
# Defaults resolve to the repo root; override if your layout differs.
# RADIO_ENGINE_ROOT=/absolute/path/to/NeuralRadio
# RADIO_UV_PATH=uv
