  {
    "name": "insert_announcement",
    "description": "Render a SHORT spoken message and air it on a LIVE stream immediately (breaking news, live read, time-sensitive info). With play_next=true it plays right after the current segment. Use this for timely one-off speech; use update_program for recurring content.",
    "parameters": {
      "type": "object",
      "properties": {
        "stream_id": {
          "type": "string",
          "description": "Live stream to interrupt."
        },
        "text": {
          "type": "string"
        },
        "voice": {
          "type": "string",
          "nullable": true
        },
        "play_next": {
          "type": "boolean"
        }
      },
      "required": [
        "stream_id",
        "text"
      ]
    }
  },
  {
    "name": "create_backend",
    "description": "Register an audio (music) or TTS (speech) backend. Provider mock needs no config; kokoro/stable_audio reuse the real engine.",
    "parameters": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "speech",
            "music"
          ]
        },
        "provider": {
          "type": "string",
          "enum": [
            "mock",
            "kokoro",
            "stable_audio"
          ]
        },
        "config": {
          "type": "object",
          "properties": {}
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "kind",
        "provider"
      ]
    }
  },
  {
    "name": "create_program",
    "description": "Create an orchestration program: a music bed plus spoken inserts (news/info/ad/station_id/weather) with cadence, scripts, ducking.",
    "parameters": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "music_backend_id": {
          "type": "string",
          "nullable": true
        },
        "speech_backend_id": {
          "type": "string",
          "nullable": true
        },
        "config": {
          "type": "object",
          "properties": {
            "target_lufs": {
              "type": "number"
            },
            "crossfade_seconds": {
              "type": "number"
            },
            "music": {
              "type": "object",
              "properties": {
                "prompts": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "genre": {
                  "type": "string",
                  "nullable": true
                },
                "track_seconds": {
                  "type": "number"
                },
                "crossfade_seconds": {
                  "type": "number"
                }
              }
            },
            "inserts": {
              "type": "array",
              "items": {
                "type": "object",
                "description": "A spoken/asset element periodically woven into the music (feature #2).",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "news",
                      "info",
                      "ad",
                      "station_id",
                      "jingle",
                      "weather"
                    ]
                  },
                  "cadence_seconds": {
                    "type": "number"
                  },
                  "texts": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "voice": {
                    "type": "string",
                    "nullable": true
                  },
                  "asset": {
                    "type": "string",
                    "nullable": true
                  },
                  "ducking": {
                    "type": "boolean"
                  },
                  "bed_volume_db": {
                    "type": "number"
                  },
                  "insert_volume_db": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      },
      "required": [
        "name"
      ]
    }
  },
