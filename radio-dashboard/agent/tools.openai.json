  {
    "type": "function",
    "function": {
      "name": "create_program",
      "description": "Create an orchestration program: a music bed plus spoken inserts (news/info/ad/station_id/weather) with cadence, scripts, ducking.",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "description": {
            "default": "",
            "title": "Description",
            "type": "string"
          },
          "music_backend_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Music Backend Id"
          },
          "speech_backend_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Speech Backend Id"
          },
          "config": {
            "$ref": "#/$defs/ProgramConfig"
          }
        },
        "required": [
          "name"
        ],
        "$defs": {
          "InsertSpec": {
            "additionalProperties": true,
            "description": "A spoken/asset element periodically woven into the music (feature #2).",
            "properties": {
              "kind": {
                "default": "info",
                "enum": [
                  "news",
                  "info",
                  "ad",
                  "station_id",
                  "jingle",
                  "weather"
                ],
                "title": "Kind",
                "type": "string"
              },
              "cadence_seconds": {
                "default": 600.0,
                "title": "Cadence Seconds",
                "type": "number"
              },
              "texts": {
                "items": {
                  "type": "string"
                },
                "title": "Texts",
                "type": "array"
              },
              "voice": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Voice"
              },
              "asset": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Asset"
              },
              "ducking": {
                "default": true,
                "title": "Ducking",
                "type": "boolean"
              },
              "bed_volume_db": {
                "default": -8.0,
                "title": "Bed Volume Db",
                "type": "number"
              },
              "insert_volume_db": {
                "default": 0.0,
                "title": "Insert Volume Db",
                "type": "number"
              }
            },
            "title": "InsertSpec",
            "type": "object"
          },
          "MusicSpec": {
            "additionalProperties": true,
            "properties": {
              "prompts": {
                "items": {
                  "type": "string"
                },
                "title": "Prompts",
                "type": "array"
              },
              "genre": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Genre"
              },
              "track_seconds": {
                "default": 210.0,
                "title": "Track Seconds",
                "type": "number"
              },
              "crossfade_seconds": {
                "default": 4.0,
                "title": "Crossfade Seconds",
                "type": "number"
              }
            },
            "title": "MusicSpec",
            "type": "object"
          },
          "ProgramConfig": {
            "additionalProperties": true,
            "properties": {
              "target_lufs": {
                "default": -16.0,
                "title": "Target Lufs",
                "type": "number"
              },
              "crossfade_seconds": {
                "default": 4.0,
                "title": "Crossfade Seconds",
                "type": "number"
              },
              "music": {
                "$ref": "#/$defs/MusicSpec"
              },
              "inserts": {
                "items": {
                  "$ref": "#/$defs/InsertSpec"
                },
                "title": "Inserts",
                "type": "array"
              }
            },
            "title": "ProgramConfig",
            "type": "object"
          }
        }
      }
    }
  },
