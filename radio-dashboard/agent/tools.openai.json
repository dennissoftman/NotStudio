  {
    "type": "function",
    "function": {
      "name": "create_stream",
      "description": "Create a channel bound to a program, with buffer/batch settings and optional Icecast publishing.",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "program_id": {
            "anyOf": [
