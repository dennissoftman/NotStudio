          },
          "sample_rate": {
            "default": 44100,
            "title": "Sample Rate",
            "type": "integer"
          },
          "channels": {
            "default": 2,
            "title": "Channels",
            "type": "integer"
          },
          "buffer_min_seconds": {
            "default": 900.0,
            "title": "Buffer Min Seconds",
            "type": "number"
