  {
    "name": "create_stream",
    "description": "Create a channel bound to a program, with buffer/batch settings and optional Icecast publishing.",
    "input_schema": {
      "type": "object",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "program_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Program Id"
        },
        "sample_rate": {
          "default": 44100,
          "title": "Sample Rate",
          "type": "integer"
        },
        "channels": {
          "default": 2,
          "title": "Channels",
          "type": "integer"
        },
        "buffer_min_seconds": {
          "default": 900.0,
          "title": "Buffer Min Seconds",
          "type": "number"
        },
        "batch_target_seconds": {
          "default": 1080.0,
          "title": "Batch Target Seconds",
          "type": "number"
        },
        "batch_max_seconds": {
          "default": 1200.0,
          "title": "Batch Max Seconds",
          "type": "number"
        },
        "icecast": {
          "anyOf": [
            {
              "$ref": "#/$defs/IcecastConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name"
      ],
      "$defs": {
        "IcecastConfig": {
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "default": false,
              "title": "Enabled",
              "type": "boolean"
            },
            "host": {
              "default": "localhost",
              "title": "Host",
              "type": "string"
            },
            "port": {
              "default": 8010,
              "title": "Port",
              "type": "integer"
            },
            "mount": {
              "default": "/neural.mp3",
              "title": "Mount",
              "type": "string"
            },
            "username": {
              "default": "source",
              "title": "Username",
              "type": "string"
            },
            "password": {
              "default": "hackme",
              "title": "Password",
              "type": "string"
            },
            "format": {
              "default": "mp3",
              "enum": [
                "mp3",
                "ogg"
              ],
              "title": "Format",
              "type": "string"
            }
          },
          "title": "IcecastConfig",
          "type": "object"
        }
      }
    }
  },
