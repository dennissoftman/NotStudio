[
  {
    "name": "get_station_state",
    "description": "Snapshot of the whole station: streams with live buffer status, active jobs, programs, backends and provider availability. ALWAYS call this first to ground yourself before acting.",
    "input_schema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "list_streams",
    "description": "List all channels and their status.",
    "input_schema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "get_buffer_status",
    "description": "Buffer readiness for one stream: ready_seconds vs min_seconds, whether a batch is generating, and segment counts.",
    "input_schema": {
      "type": "object",
      "properties": {
        "stream_id": {
          "type": "string",
          "description": "Stream id."
        }
      },
      "required": [
        "stream_id"
      ]
    }
  },
  {
    "name": "list_jobs",
    "description": "List generation jobs (most recent first). Optionally filter by stream or status (queued|in_progress|completed|failed|cancelled).",
    "input_schema": {
      "type": "object",
      "properties": {
        "stream_id": {
          "type": "string",
          "description": "Filter to one stream."
        },
        "status": {
          "type": "string",
          "description": "Filter by job status."
        }
      }
    }
  },
  {
    "name": "get_job",
    "description": "Fetch one job to track its status, progress and result/error.",
    "input_schema": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "description": "Job id."
        }
      },
      "required": [
        "job_id"
      ]
    }
  },
  {
    "name": "list_programs",
    "description": "List orchestration programs (recipes).",
    "input_schema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "list_backends",
    "description": "List configured audio/TTS backends.",
    "input_schema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "list_providers",
    "description": "List backend providers (mock/kokoro/stable_audio) and whether each is available in this environment.",
    "input_schema": {
      "type": "object",
      "properties": {}
    }
  },
  {
    "name": "list_schedules",
    "description": "List schedules.",
    "input_schema": {
      "type": "object",
