  {
    "name": "create_schedule",
    "description": "Schedule recurring/one-shot actions: render_batch, start_stream or stop_stream, via interval (seconds), cron (5-field, UTC) or date (run_at).",
    "input_schema": {
      "type": "object",
      "properties": {
        "name": {
          "title": "Name",
